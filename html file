<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Smart City Emergency Dashboard</title>
    <style>
        :root {
            --bg: #030712;
            --card: #111827;
            --accent: #10b981;
            --danger: #ef4444;
            --road: #374151;
            --text: #f3f4f6;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            color: var(--text);
            display: flex;
            justify-content: center;
            padding: 20px;
            margin: 0;
        }

        .dashboard {
            width: 1200px;
            display: grid;
            grid-template-columns: 1fr 350px;
            gap: 20px;
        }

        /* --- MAP AREA --- */
        .map-panel {
            background: var(--card);
            border-radius: 20px;
            padding: 25px;
            border: 1px solid #1f2937;
            position: relative;
        }

        .city-grid {
            position: relative;
            height: 550px;
            background: #000;
            border-radius: 15px;
            border: 2px solid #1f2937;
            background-image: radial-gradient(#1f2937 1px, transparent 1px);
            background-size: 30px 30px;
            overflow: hidden;
        }

        svg#roads {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            z-index: 1;
        }

        .location {
            position: absolute;
            background: #1f2937;
            padding: 8px 12px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            border: 1px solid #374151;
            z-index: 5;
            transition: 0.4s;
            white-space: nowrap;
        }

        .location.active {
            background: var(--accent);
            border-color: white;
            box-shadow: 0 0 20px var(--accent);
            color: black;
            transform: scale(1.1);
        }

        .location.hospital { border: 2px solid #3b82f6; color: #3b82f6; }

        .ambulance {
            position: absolute;
            font-size: 32px;
            z-index: 10;
            transition: all 1s cubic-bezier(0.4, 0, 0.2, 1);
            margin-left: -16px;
            margin-top: -16px;
            display: none;
            filter: drop-shadow(0 0 10px red);
        }

        /* --- SIDEBAR --- */
        .sidebar { display: flex; flex-direction: column; gap: 20px; }

        .control-box {
            background: var(--card);
            padding: 20px;
            border-radius: 15px;
            border: 1px solid #1f2937;
        }

        select, button {
            width: 100%;
            padding: 12px;
            margin-top: 10px;
            border-radius: 8px;
            border: none;
            font-weight: bold;
        }

        select { background: #1f2937; color: white; border: 1px solid #374151; }

        button { background: var(--accent); color: white; cursor: pointer; text-transform: uppercase; }
        button:hover { background: #059669; }

        #logs {
            height: 300px;
            background: #000;
            padding: 15px;
            border-radius: 10px;
            font-family: 'Courier New', monospace;
            font-size: 12px;
            color: var(--accent);
            overflow-y: auto;
            border: 1px solid #1f2937;
        }

        .tag { font-size: 10px; padding: 2px 5px; border-radius: 3px; margin-right: 5px; }
        .tag-jam { background: var(--danger); color: white; }
    </style>
</head>
<body>

<div class="dashboard">
    <div class="map-panel">
        <h2 style="margin: 0 0 15px 0;">🏙️ Smart City: AI Traffic Corridor</h2>
        <div class="city-grid" id="city">
            <svg id="roads"></svg>
            <div class="ambulance" id="amb">🚑</div>
            </div>
    </div>

    <div class="sidebar">
        <div class="control-box">
            <label>📍 Current Location:</label>
            <select id="startLoc"></select>
            <button onclick="startEmergency()">🚨 Start Emergency</button>
            <button onclick="location.reload()" style="background:#4b5563; margin-top:5px">🔄 Reset</button>
        </div>

        <div class="control-box">
            <div style="font-size: 12px; color: #9ca3af; margin-bottom: 10px;">SYSTEM LOGS</div>
            <div id="logs">> GPS Initialized...<br>> Waiting for Emergency Call.</div>
        </div>
    </div>
</div>

<script>
    // Locations (Real Names & Pixels)
    const locations = {
        "A": { name: "Airport Road", x: 10, y: 20 },
        "B": { name: "Main Market", x: 40, y: 15 },
        "C": { name: "Industrial Estate", x: 75, y: 10 },
        "D": { name: "Railway Station", x: 15, y: 55 },
        "E": { name: "Tech Park", x: 45, y: 45 },
        "F": { name: "Residential Zone", x: 80, y: 50 },
        "G": { name: "Old Town", x: 20, y: 85 },
        "H": { name: "Highway Entry", x: 55, y: 85 },
        "I": { name: "Metro Station", x: 85, y: 25 },
        "J": { name: "City Hospital", x: 90, y: 80 } // HOSPITAL
    };

    // Connections (Roads with Traffic Weights)
    const roads = [
        { u: "A", v: "B", w: 2 }, { u: "A", v: "D", w: 1 },
        { u: "B", v: "C", w: 10 }, { u: "B", v: "E", w: 2 }, // Red road (Weight 10)
        { u: "C", v: "I", w: 1 }, { u: "D", v: "E", w: 8 },
        { u: "D", v: "G", w: 1 }, { u: "E", v: "F", w: 2 },
        { u: "E", v: "H", w: 1 }, { u: "F", v: "I", w: 1 },
        { u: "F", v: "J", w: 1 }, { u: "G", v: "H", w: 2 },
        { u: "H", v: "J", w: 1 }, { u: "I", v: "J", w: 15 } // Traffic near Hospital
    ];

    // Initialize Map
    const city = document.getElementById('city');
    const svg = document.getElementById('roads');
    const startSelect = document.getElementById('startLoc');

    // 1. Draw Roads
    roads.forEach(r => {
        const line = document.createElementNS("http://www.w3.org/2000/svg", "line");
        line.setAttribute("x1", locations[r.u].x + "%");
        line.setAttribute("y1", locations[r.u].y + "%");
        line.setAttribute("x2", locations[r.v].x + "%");
        line.setAttribute("y2", locations[r.v].y + "%");
        line.setAttribute("stroke", r.w > 5 ? "#ef4444" : "#374151");
        line.setAttribute("stroke-width", r.w > 5 ? "4" : "2");
        line.id = `road-${r.u}-${r.v}`;
        svg.appendChild(line);
    });

    // 2. Draw Locations
    Object.keys(locations).forEach(id => {
        const div = document.createElement('div');
        div.className = id === 'J' ? 'location hospital' : 'location';
        div.id = `loc-${id}`;
        div.style.left = locations[id].x + "%";
        div.style.top = locations[id].y + "%";
        div.innerHTML = `${locations[id].name}`;
        city.appendChild(div);

        if(id !== 'J') {
            const opt = document.createElement('option');
            opt.value = id; opt.text = locations[id].name;
            startSelect.add(opt);
        }
    });

    function addLog(msg, color = "#10b981") {
        const logBox = document.getElementById('logs');
        logBox.innerHTML += `<div style="color:${color}">> [${new Date().toLocaleTimeString()}] ${msg}</div>`;
        logBox.scrollTop = logBox.scrollHeight;
    }

    // 3. Dijkstra Pathfinding
    function findPath(start, end) {
        let dist = {}, prev = {}, q = new Set(Object.keys(locations));
        Object.keys(locations).forEach(v => dist[v] = Infinity);
        dist[start] = 0;

        while(q.size > 0) {
            let u = [...q].reduce((min, n) => dist[n] < dist[min] ? n : min);
            if(u === end) break;
            q.delete(u);

            roads.filter(r => r.u === u || r.v === u).forEach(r => {
                let v = r.u === u ? r.v : r.u;
                let alt = dist[u] + r.w;
                if(alt < dist[v]) { dist[v] = alt; prev[v] = u; }
            });
        }
        let path = [], curr = end;
        while(curr) { path.push(curr); curr = prev[curr]; }
        return path.reverse();
    }

    // 4. Run Emergency
    async function startEmergency() {
        const start = startSelect.value;
        const end = 'J';
        const amb = document.getElementById('amb');

        addLog(`🚨 EMERGENCY! Ambulance dispatched from ${locations[start].name}`, "#ef4444");
        const path = findPath(start, end);
        addLog(`🛰️ Calculating bypass for heavy traffic...`);

        amb.style.display = "block";

        for(let i=0; i < path.length; i++) {
            const locId = path[i];
            const el = document.getElementById(`loc-${locId}`);
            
            // Move Ambulance
            amb.style.left = locations[locId].x + "%";
            amb.style.top = locations[locId].y + "%";

            // Sync Visuals
            el.classList.add('active');
            if(i > 0) {
                const roadId = `road-${path[i-1]}-${path[i]}` || `road-${path[i]}-${path[i-1]}`;
                const road = document.getElementById(roadId);
                if(road) { road.setAttribute('stroke', '#10b981'); road.setAttribute('stroke-width', '6'); }
            }

            addLog(`🟢 Corridor Activated: ${locations[locId].name}`);
            await new Promise(r => setTimeout(r, 1200));
        }
        addLog(`🏁 PATIENT DELIVERED TO HOSPITAL.`, "#3b82f6");
    }
</script>
</body>
</html>
